{
  "name": "@agent-operator/server-core",
  "version": "0.7.1",
  "description": "Reusable headless server infrastructure for Dazi",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./transport": "./src/transport/index.ts",
    "./runtime": "./src/runtime/index.ts",
    "./handlers": "./src/handlers/index.ts",
    "./bootstrap": "./src/bootstrap/index.ts",
    "./model-fetchers": "./src/model-fetchers/index.ts",
    "./domain": "./src/domain/index.ts",
    "./services": "./src/services/index.ts",
    "./handlers/rpc": "./src/handlers/rpc/index.ts",
    "./handlers/rpc/*": "./src/handlers/rpc/*.ts",
    "./sessions": "./src/sessions/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-operator/core": "workspace:*",
    "@agent-operator/shared": "workspace:*",
    "ws": "^8.19.0",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "@types/node": "^22.0.0"
  }
}
